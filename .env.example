# Supabase — webinar migration project (nqsyzxwamtwjrhokpjof)
# Copy this file to .env.local and fill in the keys.

# --- Server-only (NEVER exposed to the browser). Bypasses RLS for data queries. ---
SUPABASE_URL=https://nqsyzxwamtwjrhokpjof.supabase.co
# Dashboard > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_here

# n8n webhook fired when a new webinar is created (back-fills unregistered leads). Server-only.
N8N_WEBINAR_WEBHOOK_URL=

# --- Public (safe to expose). Used only by the browser auth client for login. ---
NEXT_PUBLIC_SUPABASE_URL=https://nqsyzxwamtwjrhokpjof.supabase.co
# Dashboard > Project Settings > API > anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=paste_anon_key_here
